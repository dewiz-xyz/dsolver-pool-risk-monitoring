{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "title": "High Risk Pools (Score)",
      "type": "barchart",
      "datasource": "prometheus",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "high_risk_pools_score",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "axisLabel": "Risk Score",
            "axisPlacement": "left",
            "scaleDistribution": {
              "type": "linear"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "currencies": true,
              "pool": true,
              "risk_level": true,
              "Metric": true
            },
            "indexByName": {
              "pool_address": 0,
              "Value": 1
            },
            "renameByName": {
              "Value": "risk_score"
            }
          }
        }
      ],
      "options": {
        "xField": "pool_address",
        "orientation": "vertical",
        "showValue": "auto",
        "stacking": "none",
        "barWidth": 0.97,
        "groupWidth": 0.7,
        "legend": {
          "displayMode": "hidden",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "title": "Risk Level Summary",
      "type": "table",
      "datasource": "prometheus",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "expr": "risk_level_summary_total",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {}
      },
      "options": {
        "showHeader": true
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 38,
  "style": "dark",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "Pool Risk Monitoring (Derived Metrics)",
  "uid": "tycho-risk",
  "version": 2
}
